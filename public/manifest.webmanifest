{
  "name": "EPUB Reader",
  "short_name": "EpubReader",
  "description": "A private, walled-garden EPUB reader web application.",
  "display": "standalone",
  "start_url": "/dashboard",
  "scope": "/",
  "id": "/dashboard",
  "orientation": "any",
  "theme_color": "#1a1f36",
  "background_color": "#ffffff",
  "categories": ["books", "education"],
  "icons": [
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Dashboard",
      "short_name": "Library",
      "url": "/dashboard",
      "description": "Open your library and continue reading"
    },
    {
      "name": "Settings",
      "short_name": "Settings",
      "url": "/settings",
      "description": "Adjust reader preferences and manage offline downloads"
    }
  ]
}
