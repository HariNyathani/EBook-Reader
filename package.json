{
  "name": "epub-reader",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test tests/e2e/a11y",
    "test:coverage": "vitest run --coverage",
    "smoke": "tsx scripts/smoke.ts",
    "verify:migrations": "tsx scripts/verify-migrations.ts",
    "perf:budgets": "tsx scripts/check-performance-budgets.ts",
    "db:types": "supabase gen types typescript --local > src/types/database.ts",
    "db:migrate": "supabase db push",
    "db:migrate:prod": "supabase db push --include-all",
    "bootstrap:admin": "tsx scripts/bootstrap-admin.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3",
    "@aws-sdk/s3-request-presigner": "3",
    "@sentry/nextjs": "^10.63.0",
    "@serwist/next": "^9.5.11",
    "@supabase/ssr": "0.5",
    "@supabase/supabase-js": "2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "clsx": "2",
    "dotenv": "16",
    "fast-xml-parser": "^5.9.3",
    "framer-motion": "^12.42.2",
    "idb-keyval": "6",
    "lucide-react": "^1.23.0",
    "next": "^15.3.4",
    "node-stream-zip": "^1.15.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "server-only": "^0.0.1",
    "serwist": "^9.5.11",
    "sharp": "^0.35.3",
    "tailwind-merge": "2",
    "zod": "3",
    "zustand": "5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@next/bundle-analyzer": "^16.2.10",
    "@playwright/test": "1",
    "@testing-library/jest-dom": "6",
    "@testing-library/react": "16",
    "@testing-library/user-event": "14",
    "@types/archiver": "^8.0.0",
    "@types/node": "^20.19.43",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.5",
    "@vercel/speed-insights": "^2.0.0",
    "@vitejs/plugin-react": "4",
    "@vitest/coverage-v8": "^2.1.9",
    "archiver": "^8.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.30.0",
    "eslint-config-next": "^15.3.4",
    "jsdom": "25",
    "postcss": "^8.5.6",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^3.4.17",
    "tsx": "4",
    "typescript": "^5.8.3",
    "vitest": "2"
  }
}
