# Environment variables for the Private EPUB Reader application.
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and must NEVER be committed.
# See docs/implementation/ISD-Phases-0-4.md §2.J and ISD-Phases-13-16.md §15.K.

# --- App Environment (Phase 15, ISD §15.K) ---
# One of: development | preview | production
# Production build REQUIRES Upstash + Sentry (or explicit opt-out).
APP_ENV=development

# --- Supabase (consumed from Phase 3) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Cloudflare R2 (consumed Phase 2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=epub-reader-assets

# --- Upload Configuration (Phase 6) ---
# Upload strategy: 'stream' (default) or 'presigned' (for hosts with small body limits)
UPLOAD_STRATEGY=stream
# Maximum upload file size in bytes (default: 50 MB)
MAX_UPLOAD_BYTES=52428800
# Server Actions body size limit (must match MAX_UPLOAD_BYTES)
SERVER_ACTIONS_BODY_LIMIT=50mb

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- PWA (Phase 13, ISD §13.K) ---
# Set to 'true' to enable the service worker in development. Default
# (unset / 'true') means the SW is registered in production only. Set
# to 'false' to disable the SW entirely (e.g. preview environments
# where the offline infrastructure is not ready).
NEXT_PUBLIC_PWA_ENABLED=true
# Optional: force the SW in dev. Useful when developing SW + offline flows.
NEXT_PUBLIC_SW_DEV=false

# --- Web Vitals (Phase 14, ISD §14.K) ---
# Optional. When set, the Web Vitals reporter POSTs PII-free metrics
# to this URL as a fire-and-forget beacon. Defaults to no-op (we rely
# on Vercel Speed Insights when installed).
# NEXT_PUBLIC_VITALS_ENDPOINT=https://example.com/api/vitals
NEXT_PUBLIC_VITALS_ENDPOINT=

# --- Rate Limiting (Phase 15, ISD §15.G, §15.B) ---
# Upstash Redis (REST) for distributed rate limiting. When these
# are unset, the rate limiter falls back to an in-memory implementation
# (single-region, best-effort) with a documented log message.
# Both must be set together; partial config triggers the fallback.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Sentry (Phase 15, ISD §15.G, §15.D) ---
# Sentry DSN. Server-side is the canonical DSN; NEXT_PUBLIC_SENTRY_DSN
# is the browser-side DSN (safe to expose). When unset, the SDK is a
# no-op. Required in production unless SENTRY_REQUIRED=false.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Set to 'false' to skip the browser SDK entirely (useful in E2E tests).
NEXT_PUBLIC_SENTRY_ENABLED=true
# CI-only: token for uploading source maps to Sentry.
SENTRY_AUTH_TOKEN=
# Sentry release identifier (usually the git SHA or a semver tag).
SENTRY_RELEASE=
# Sentry organization + project for the withSentryConfig wrapper.
SENTRY_ORG=
SENTRY_PROJECT=
# Traces sample rate (0..1). Default: 0.1.
SENTRY_TRACES_SAMPLE_RATE=0.1
# Set to 'false' in a temporary diagnostic deploy where you cannot
# configure Sentry. NEVER set this in steady-state production.
SENTRY_REQUIRED=true

# --- Logging (Phase 15, ISD §15.G) ---
# Minimum log level: trace | debug | info | warn | error | fatal.
# Default: debug in dev, info in prod.
LOG_LEVEL=info
# Service name (added to every log entry).
SERVICE_NAME=epub-reader
